# Plantilla de credenciales RRSS — COPIA este archivo a `.env` y rellena los valores.
# El `.env` real está en .gitignore y NUNCA se sube al repo.
# Cuando pasemos a GitHub Actions, estos mismos nombres se cargan como GitHub Secrets.

# --- Bluesky ---
# BLUESKY_HANDLE: el handle completo de la cuenta.
# BLUESKY_APP_PASSWORD: el App Password de 19 caracteres (Settings → App Passwords),
#                       NO la contraseña real de la cuenta.
BLUESKY_HANDLE=ele-de-anais.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Reddit (cuando exista) ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# --- Pixiv (cuando exista) ---
# PIXIV_REFRESH_TOKEN=
